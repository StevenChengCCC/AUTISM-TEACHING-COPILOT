APP_NAME=Autism Teaching Copilot
ENV=development
DATABASE_URL=sqlite:///./autism_copilot.db
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEV_ALLOW_ANON_TEACHER=true
DEV_ANON_TEACHER_ID=1

# AI provider: mock | azure_openai | openai
AI_PROVIDER=mock

# Azure OpenAI placeholders
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_IMAGE_DEPLOYMENT=

# OpenAI placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional image search providers. MVP runs without them using deterministic mock candidates.
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
