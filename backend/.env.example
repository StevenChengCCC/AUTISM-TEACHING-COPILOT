APP_ENV=development
APP_VERSION=v2-product
LOG_LEVEL=INFO
AI_PROVIDER=mock
AI_FAILURE_MODE=mock_fallback
ACTIVE_LEARNER_PROFILE_SKILL_VERSION=v1
ACTIVE_LESSON_PLANNING_SKILL_VERSION=v1
ACTIVE_LESSON_GENERATION_SKILL_VERSION=v1
ACTIVE_MATERIAL_GENERATION_SKILL_VERSION=v1
ACTIVE_IMAGE_GENERATION_SKILL_VERSION=v1
# Optional override; defaults to backend/app/skills.
SKILL_ROOT=

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_PROFILE_MODEL=gpt-4.1-mini
OPENAI_PLANNING_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_TIMEOUT_SECONDS=60
OPENAI_PROFILE_TIMEOUT_SECONDS=45
OPENAI_PLANNING_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=0
OPENAI_REASONING_EFFORT=low
IMAGE_ASSET_STRATEGY=generate_first

ALLOWED_ORIGINS=http://localhost:5173
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
KEY_VAULT_URL=

APP_NAME=Lesson Kit Studio API
DATABASE_URL=sqlite:///./autism_copilot.db
TEST_DATABASE_URL=
V2_REPOSITORY_MODE=memory
V2_SEED_SYNTHETIC_DATA=true
V2_DEFAULT_ORGANIZATION_ID=demo-organization
V2_DEFAULT_USER_ID=demo-teacher

# Optional AWS Elastic Beanstalk RDS variables:
RDS_HOSTNAME=
RDS_PORT=5432
RDS_DB_NAME=
RDS_USERNAME=
RDS_PASSWORD=
STORAGE_DIR=./storage
DEV_ALLOW_ANON_TEACHER=true
DEV_ANON_TEACHER_ID=1
AUTH_MODE=demo
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_ORGANIZATION_CLAIM=custom:organization_id
COGNITO_DEFAULT_ORGANIZATION_ID=demo-organization
COGNITO_ADMIN_GROUP=lesson-kit-admins

AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_IMAGE_DEPLOYMENT=

# Optional image search providers. MVP runs without them using deterministic mock candidates.
IMAGE_SEARCH_TIMEOUT_SECONDS=10
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# Private learner-record upload and parsing. Local storage is development/test only.
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=.txt,.pdf,.docx
ALLOWED_UPLOAD_MIME_TYPES=text/plain,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_QUARANTINE_DIR=./storage/quarantine
OBJECT_STORAGE_PROVIDER=local
LOCAL_PRIVATE_STORAGE_DIR=./private-storage/learner-records
LOCAL_UPLOAD_SIGNING_SECRET=
PUBLIC_API_BASE_URL=http://localhost:8000
S3_BUCKET=
S3_REGION=
S3_UPLOAD_PREFIX=learner-records
S3_EXPORT_PREFIX=teacher-handoff-exports
S3_PRESIGNED_TTL_SECONDS=300
EXPORT_DOWNLOAD_TTL_SECONDS=300
EXPORT_RETENTION_DAYS=7
MAX_EXPORT_BYTES=52428800
S3_SERVER_SIDE_ENCRYPTION=AES256
S3_KMS_KEY_ID=
MIN_EXTRACTED_TEXT_CHARS=20
ENABLE_UPLOAD_ANTIVIRUS_SCAN=false
MAX_UNTRUSTED_RECORD_TEXT_CHARS=50000
